{
  "name": "bd-platform",
  "private": true,
  "scripts": {
    "build": "next build --webpack",
    "build:bdi": "BRAND=bdi NEXT_PUBLIC_BRAND=bdi next build --webpack",
    "build:cmbd": "BRAND=cmbd NEXT_PUBLIC_BRAND=cmbd next build --webpack",
    "vercel-build": "if [ \"$VERCEL_ENV\" = production ]; then prisma migrate deploy; fi && next build --webpack",
    "dev": "next dev --webpack",
    "dev:bdi": "BRAND=bdi NEXT_PUBLIC_BRAND=bdi next dev --webpack",
    "dev:cmbd": "BRAND=cmbd NEXT_PUBLIC_BRAND=cmbd next dev --webpack",
    "dev:local": "POSTGRES_URL=postgresql://admin:admin@localhost:5432/bd_platform POSTGRES_URL_NON_POOLING=postgresql://admin:admin@localhost:5432/bd_platform BRAND=bdi NEXT_PUBLIC_BRAND=bdi next dev --webpack",
    "start": "next start",
    "lint": "eslint .",
    "seed:bdi": "BRAND=bdi NEXT_PUBLIC_BRAND=bdi node -r dotenv/config ./scripts/seed-bdi.js",
    "db:up": "docker compose up -d --wait",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d --wait",
    "db:setup": "bash scripts/test-db.sh --seed",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run __tests__/integration",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@heroicons/react": "^2.0.18",
    "@prisma/client": "^5.6.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.0.0",
    "lucide-react": "^0.577.0",
    "next": "^16.1.6",
    "next-auth": "^5.0.0-beta.30",
    "next-intl": "^4.8.3",
    "next-themes": "^0.4.6",
    "papaparse": "^5.5.3",
    "postcss": "8.4.31",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.0.8",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "use-debounce": "^9.0.4",
    "zod": "^3.22.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "dotenv": "^16.3.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "jsdom": "^28.1.0",
    "prettier": "^3.0.3",
    "prisma": "^5.6.0",
    "typescript": "^5.2.2",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=18"
  }
}
