generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("POSTGRES_PRISMA_URL") // uses connection pooling
  directUrl = env("POSTGRES_URL_NON_POOLING") // uses a direct connection
}

model Author {
  id     String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bd_ids String[] @db.Uuid
  bds    BdAuthor[]
  events AuthorEvent[]
  name   String   @unique @db.VarChar(255)
}

model Bd {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  event_ids       String   @db.Uuid
  author_ids      String[] @db.Uuid
  event           Event   @relation(fields: [event_ids], references: [id])
  authors         BdAuthor[]
  title           String   @unique @db.VarChar(255)
  publicher       String?
  publishing_year Int?
}

model Event {
  id       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name     String   @unique @db.VarChar(255)
  bds      Bd[]
  authors  AuthorEvent[]
  date     DateTime @unique @db.Date
  bd_ids   String[] @db.Uuid
  fb_event String?
}

model users {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name     String @db.VarChar(255)
  email    String @unique
  password String
}

model BdAuthor {

  bd        Bd @relation(fields: [bdId], references: [id])
  bdId      String @db.Uuid // relation scalar field (used in the `@relation` attribute above)
  author    Author @relation(fields: [authorId], references: [id])
  authorId  String @db.Uuid 

  @@id([authorId, bdId])
}

model AuthorEvent {
  author    Author @relation(fields: [authorId], references: [id])
  event     Event @relation(fields: [eventId], references: [id])
  authorId  String @db.Uuid
  eventId   String @db.Uuid

  @@id([authorId, eventId])
}
