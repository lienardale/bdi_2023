generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("POSTGRES_URL")
}

model Author {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bds           BdAuthor[]
  events        AuthorEvent[]
  name          String        @unique @db.VarChar(255)
  bio           String?       @db.Text
  bio_source    String?       @db.VarChar(50)
  photo_url     String?       @db.Text
  wikipedia_url String?       @db.Text
}

model Publisher {
  id       String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name     String      @unique @db.VarChar(255)
  parentId String?     @db.Uuid
  parent   Publisher?  @relation("PublisherImprints", fields: [parentId], references: [id])
  imprints Publisher[] @relation("PublisherImprints")
  bds      Bd[]
}

model Bd {
  id               String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  events           BdEvent[]
  authors          BdAuthor[]
  title            String      @unique @db.VarChar(255)
  publisher        String?
  publisherId      String?     @db.Uuid
  publisherRef     Publisher?  @relation(fields: [publisherId], references: [id])
  publishing_year  Int?
  ean              String?     @db.VarChar(13)
  summary          String?     @db.Text
  publication_date DateTime?   @db.Date
  page_count       Int?
  price            Decimal?    @db.Decimal(10, 2)
  cover_url          String?   @db.Text
  publisher_url      String?   @db.Text
  leslibraires_url   String?   @db.Text
  enrichment_source  String?   @db.VarChar(50)
}

model Event {
  id       String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name     String        @unique @db.VarChar(255)
  bds      BdEvent[]
  authors  AuthorEvent[]
  date     DateTime      @unique @db.Date
  hour     String?       @db.VarChar(5)
  place    String?       @db.VarChar(255)
  fb_event  String?
  cover_url String?  @db.Text
}

model BdAuthor {
  bd       Bd     @relation(fields: [bdId], references: [id])
  bdId     String @db.Uuid
  author   Author @relation(fields: [authorId], references: [id])
  authorId String @db.Uuid

  @@id([authorId, bdId])
}

model AuthorEvent {
  author   Author @relation(fields: [authorId], references: [id])
  event    Event  @relation(fields: [eventId], references: [id])
  authorId String @db.Uuid
  eventId  String @db.Uuid

  @@id([authorId, eventId])
}

model BdEvent {
  bd      Bd     @relation(fields: [bdId], references: [id])
  bdId    String @db.Uuid
  event   Event  @relation(fields: [eventId], references: [id])
  eventId String @db.Uuid

  @@id([bdId, eventId])
}
