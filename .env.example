# Brand selection. Must be 'bdi' or 'cmbd'. Both vars must match.
# BRAND is server-only; NEXT_PUBLIC_BRAND is inlined into the client bundle.
BRAND=bdi
NEXT_PUBLIC_BRAND=bdi

# Each deployment points at its own Postgres instance.
POSTGRES_URL=postgresql://admin:admin@localhost:5432/bd_platform
POSTGRES_URL_NON_POOLING=postgresql://admin:admin@localhost:5432/bd_platform

# NextAuth + Google OAuth
AUTH_SECRET=your-auth-secret-here
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
AUTH_URL=http://localhost:3000

# Comma-separated list of emails allowed to access /admin.
ADMIN_EMAILS=your-admin-email@example.com
